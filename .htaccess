# Définition du bon type MIME pour WebAssembly (Crucial pour que sql-wasm.js fonctionne correctement)
AddType application/wasm .wasm

# Forcer l'encodage en UTF-8
AddDefaultCharset UTF-8

# ----------------------------------------------------------------------
# Compression GZIP
# ----------------------------------------------------------------------
<IfModule mod_deflate.c>
    # Compresser les fichiers textes, CSS, JS et WebAssembly
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json application/wasm
</IfModule>

# ----------------------------------------------------------------------
# En-têtes de Sécurité Basiques
# ----------------------------------------------------------------------
<IfModule mod_headers.c>
    # Empêche le navigateur de "deviner" le type MIME (protection contre certaines failles)
    Header set X-Content-Type-Options "nosniff"
    
    # Prévient l'inclusion de la page dans une iframe externe (Protection Clickjacking)
    Header set X-Frame-Options "SAMEORIGIN"
    
    # Active le filtre XSS natif des navigateurs
    Header set X-XSS-Protection "1; mode=block"

    # Content Security Policy
    # - script-src : uniquement self + cdnjs (JSZip, sql.js)
    # - worker-src blob: : requis par sql.js qui crée un Web Worker depuis un Blob
    # - style-src : uniquement self + Google Fonts
    # - font-src : uniquement Google Fonts
    Header set Content-Security-Policy "default-src 'self'; script-src 'self' https://cdnjs.cloudflare.com; style-src 'self' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; worker-src blob:; object-src 'none';"
</IfModule>

# ----------------------------------------------------------------------
# Mise en cache du navigateur (Performances)
# ----------------------------------------------------------------------
<IfModule mod_expires.c>
    ExpiresActive On
    
    # Mettre en cache les polices, WASM et médias pendant 1 mois
    ExpiresByType application/wasm "access plus 1 month"
    
    # Mettre en cache CSS et JS pendant 1 semaine
    ExpiresByType text/css "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
</IfModule>
